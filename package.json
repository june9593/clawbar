{
  "name": "clawbar",
  "version": "1.0.0",
  "description": "macOS menu bar chat client for OpenClaw",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "npm run build:electron && electron .",
    "build": "vite build && npm run build:electron",
    "build:electron": "tsc -p tsconfig.node.json",
    "preview": "vite preview",
    "pack:mac:dmg:arm64": "npm run build && electron-builder --mac dmg --arm64",
    "pack:mac:dmg:x64": "npm run build && electron-builder --mac dmg --x64",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit && eslint src/ electron/",
    "clean": "rm -rf dist dist-electron release-artifacts"
  },
  "keywords": [
    "openclaw",
    "menu-bar",
    "macos",
    "electron",
    "chat"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "autoprefixer": "^10.4.20",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.0",
    "vite": "^6.2.0",
    "vitest": "^3.1.0"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  }
}
